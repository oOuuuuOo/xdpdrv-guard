# xdpdrv-guard configuration
#
# Comma-separated TCP ports and ranges that should continue to accept new TCP SYN traffic.
# Any unsolicited TCP SYN to other ports is dropped at XDP layer.
#
# IMPORTANT:
# - Include every public TCP service port/range you actually use.
# - Keep this minimal. Empty means drop all unsolicited TCP SYN.
# - Tailscale SSH over tailscale0 is unaffected by this setting on eth0.
#
# Examples:
#   ALLOWED_TCP_PORTS="22,80,443,8443"
#   ALLOWED_TCP_PORTS="22,80-81,443,10000-10100"

ALLOWED_TCP_PORTS="34443"

# Optional UDP guard at XDP layer.
# When non-empty, UDP packets targeting ports outside this list are dropped at XDP.
# Empty means UDP guard is disabled (keep previous behavior).
# Examples:
#   ALLOWED_UDP_PORTS="53,3478,51820"
#   ALLOWED_UDP_PORTS="10000-10100"
ALLOWED_UDP_PORTS=""

# Auto include currently listening sshd TCP ports into runtime allow-list.
# 0 is recommended for tailscale-only SSH (avoid exposing 22 on public iface).
# Set to 1 only when you intentionally need public-IFACE SSH continuity.
AUTO_ALLOW_SSH_PORTS=0

# Optional SYN rate limit (per second) for allowed TCP ports in decoupled nft chain.
# 0 means disabled.
# Example: 2000
ALLOWED_TCP_SYN_RATE_PER_SEC=0

# Optional hard-drop list for public IFACE TCP ports (all packets, not only SYN).
# Useful for tailscale-only SSH: set BLOCK_PUBLIC_TCP_PORTS="22"
BLOCK_PUBLIC_TCP_PORTS=""

# Optional fixed interface. If empty, script auto-detects from default route.
# IFACE="eth0"

# Optional Telegram notifications
# TELEGRAM_ENABLED=1 to enable
# TELEGRAM_BOT_TOKEN from @BotFather
# TELEGRAM_CHAT_ID can be user/group/channel id
TELEGRAM_ENABLED=0
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
